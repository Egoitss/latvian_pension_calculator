# Caddy auto-provisions a Let's Encrypt certificate for this domain,
# as long as pension.oats.lv resolves to the server and 80/443 are open.
{
	email info@oats.lv
}

pension.oats.lv {
	# Access log (JSON) for visit counts. Rotated so it can't fill
	# the disk; persisted via the caddy_logs volume in compose.
	log {
		output file /var/log/caddy/access.log {
			roll_size 10MiB
			roll_keep 5
		}
	}
	reverse_proxy pension:5001
}
