# Copy to .env and fill in. .env is git-ignored.

# DeepSeek — powers the AI Review box in the downloadable PDF report.
# Get a key at https://platform.deepseek.com/ . Uses the cheap
# `deepseek-chat` model (~a fraction of a cent per report).
DEEPSEEK_API_KEY=

# Anthropic — powers the on-page AI recommendation (/api/recommend).
# Optional; that feature degrades gracefully if unset.
ANTHROPIC_API_KEY=

# Abuse / cost controls for the AI PDF export ─────────────────────
# Hard ceiling on DeepSeek calls PER DAY across all users. Once hit,
# reports still generate but without the AI box. Bounds worst-case
# daily spend (≈ limit × ~$0.00023 ≈ €0.21 at 1000). Set 0 to
# disable AI entirely.
AI_DAILY_LIMIT=1000
# Max PDF exports per IP per hour (each may trigger one AI call).
EXPORT_RATE_LIMIT=20
