# Copy to .env and fill in. .env is git-ignored.

# DeepSeek — powers the AI Review box in the downloadable PDF report.
# Get a key at https://platform.deepseek.com/ . Uses the cheap
# `deepseek-chat` model (~a fraction of a cent per report).
DEEPSEEK_API_KEY=

# Anthropic — powers the on-page AI recommendation (/api/recommend).
# Optional; that feature degrades gracefully if unset.
ANTHROPIC_API_KEY=
